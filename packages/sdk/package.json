{
  "name": "@erc-mandated/sdk",
  "description": "TypeScript SDK for ERC-8192 mandated execution workflows.",
  "version": "0.3.1",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "CC0-1.0",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
