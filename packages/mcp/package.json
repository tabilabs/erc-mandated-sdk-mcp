{
  "name": "@erc-mandated/mcp",
  "description": "MCP server and CLI for ERC-8192 mandated execution workflows.",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "CC0-1.0",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "erc-mandated-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "contracts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test ./dist/*.test.js ./dist/**/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tabilabs/erc-mandated-sdk-mcp.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/tabilabs/erc-mandated-sdk-mcp/issues"
  },
  "homepage": "https://github.com/tabilabs/erc-mandated-sdk-mcp#readme",
  "dependencies": {
    "@erc-mandated/sdk": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
